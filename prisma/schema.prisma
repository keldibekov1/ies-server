generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model User {
  id       String  @id @default(uuid())
  username String  @unique
  password String
  name     String?
  image    String?

  createdEmissions EmissionRecord[] @relation("CreatedBy")
}

model Station {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  emissions EmissionRecord[]
}

model EmissionRecord {
  id String @id @default(uuid())

  stationId String
  station   Station @relation(fields: [stationId], references: [id], onDelete: Cascade)

  year  Int
  month Int

  totalEmission Decimal @db.Decimal(16, 5)
  solidAsh      Decimal @db.Decimal(16, 5)
  nox           Decimal @db.Decimal(16, 5)
  no2           Decimal @db.Decimal(16, 5)
  no            Decimal @db.Decimal(16, 5)
  so2           Decimal @db.Decimal(16, 5)
  co            Decimal @db.Decimal(16, 5)

  createdById String?
  createdBy   User?   @relation("CreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([stationId, year, month], name: "station_year_month_unique")
  @@index([year, month])
  @@index([stationId])
}